# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# --- Environment ---
ENV=production

# --- Database ---
# Local SQLite (default, no need to set):
# DATABASE_URL=sqlite:///./toll.db
# PostgreSQL (Neon / Render / Railway):
DATABASE_URL=postgresql://user:password@host/dbname

# --- Backend ---
BACKEND_URL=https://your-api.onrender.com

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace_with_a_strong_random_hex_string

# --- CORS ---
# Comma-separated list of allowed origins (dashboard URLs)
ALLOWED_ORIGINS=https://your-dashboard.streamlit.app,https://your-api.onrender.com

# --- Camera (local .env only — not used on server) ---
VIDEO_SOURCE=http://192.168.x.x:8080/video
GANTRY_ID=PADMA_BRIDGE_NB

# --- Optional Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
